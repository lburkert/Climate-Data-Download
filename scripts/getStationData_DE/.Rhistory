# Clear environment
rm(list=ls())
# Libraries
library(this.path)
library(sf)
library(readr)
# Set path
script_path=this.path()
setwd(dirname(script_path))
# 1. Define the URL
url = "https://opendata.dwd.de/climate_environment/CDC/observations_germany/climate/hourly/air_temperature/historical/TU_Stundenwerte_Beschreibung_Stationen.txt"
# 2. Download and read the data
col_names <- c(
"Stations_id", "von_datum", "bis_datum",
"Stationshoehe", "geoBreite", "geoLaenge",
"Stationsname", "Bundesland", "Abgabe"
)
# Spaltenbreiten aus der DWD-Datei (aus der '----' Zeile)
widths <- c(5, 9, 9, 15, 12, 10, 41, 41, 6)
# Datei einlesen
stationen <- read_fwf(
file = url,
fwf_widths(widths, col_names = col_names),
skip = 2,                              # entspricht Python: skiprows=[0,1]
locale = locale(encoding = "ISO-8859-1"),  # entspricht Python encoding
trim_ws = TRUE
)
View(stationen)
View(stationen)
stationen <- stationen %>%
mutate(
Stations_id   = as.integer(Stations_id),
von_datum     = ymd(von_datum),
bis_datum     = ymd(bis_datum),
Stationshoehe = as.numeric(Stationshoehe),
geoBreite     = as.numeric(geoBreite),
geoLaenge     = as.numeric(geoLaenge),
Stationsname  = iconv(Stationsname, from="ISO-8859-1", to="UTF-8"),
Bundesland    = iconv(Bundesland, from="ISO-8859-1", to="UTF-8")
)
library(dplyr)
library(lubridate)
stationen <- stationen %>%
mutate(
Stations_id   = as.integer(Stations_id),
von_datum     = ymd(von_datum),
bis_datum     = ymd(bis_datum),
Stationshoehe = as.numeric(Stationshoehe),
geoBreite     = as.numeric(geoBreite),
geoLaenge     = as.numeric(geoLaenge),
Stationsname  = iconv(Stationsname, from="ISO-8859-1", to="UTF-8"),
Bundesland    = iconv(Bundesland, from="ISO-8859-1", to="UTF-8")
)
View(stationen)
View(stationen)
head(stationen[, c("geoBreite", "geoLaenge")])
stationen_sf <- st_as_sf(
stationen,
coords = c("geoLaenge", "geoBreite"),  # Longitude, Latitude
crs = 4326,                             # WGS84
remove = FALSE                          # Originalspalten behalten
)
