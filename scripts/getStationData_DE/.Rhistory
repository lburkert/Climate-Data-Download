###################################################################
#                                                                 #
# SCRIPT TO DOWNLOAD List of STATIONS FROM Deutscher Wetterdienst #
#                                                                 #
###################################################################
# Clear environment
rm(list=ls())
# Libraries
library(this.path)
library(sf)
library(readr)
# Set path
script_path=this.path()
setwd(dirname(script_path))
# 1. Define the URL
url = "https://opendata.dwd.de/climate_environment/CDC/observations_germany/climate/hourly/air_temperature/historical/TU_Stundenwerte_Beschreibung_Stationen.txt"
# 2. Download and read the data
col_names <- c(
"Stations_id", "von_datum", "bis_datum",
"Stationshoehe", "geoBreite", "geoLaenge",
"Stationsname", "Bundesland", "Abgabe"
)
# Spaltenbreiten aus der DWD-Datei (aus der '----' Zeile)
widths <- c(11, 9, 9, 13, 9, 9, 41, 10, 6)
# Datei einlesen
stationen <- read_fwf(
file = url,
fwf_widths(widths, col_names = col_names),
skip = 2,                              # entspricht Python: skiprows=[0,1]
locale = locale(encoding = "ISO-8859-1"),  # entspricht Python encoding
trim_ws = TRUE
)
View(stationen)
