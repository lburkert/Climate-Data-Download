})
# ----------------------------
# 1) User settings (EDIT HERE)
# ----------------------------
wk_dir  <- "C:/WK-006-TLSLeaf/"
out_dir <- file.path(wk_dir, "05_OUTPUTS")
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
fig_dir <- out_dir
# Reference: MUST contain ground-truth Classification (0/1)
ref_file <- file.path(out_dir, "LB_06_clean.laz")   # <-- change if your reference is elsewhere
# Predictions from DBSCAN & Graph (generated by 02_dbscan_graph_demo.R)
dbscan_file <- file.path(out_dir, "dbscan_pred.laz")
graph_file  <- file.path(out_dir, "graph_pred.laz")
# TLSeparation predictions (XYZ only)
tlsep_leaf_txt <- file.path(out_dir, "LB_06_clean_xyz_leaf.txt")
tlsep_wood_txt <- file.path(out_dir, "LB_06_clean_xyz_wood.txt")
# Class definition in THIS workshop
# pred = 0 wood, 1 leaf
# reference Classification should match this convention
class_levels <- c(1, 0) # keep same as your older code: levels=c(1,0)
# For DBSCAN/Graph, if pred is missing but p_wood exists, use this threshold:
pwood_threshold <- 0.90
# ----------------------------
# 2) Helpers
# ----------------------------
stop_if_missing <- function(path) {
if (!file.exists(path)) stop("File not found: ", path)
}
# Confusion matrix wrapper
confmatrix_classication <- function(ref_class, predict_class, class_list = c(1, 0)) {
ref  <- factor(ref_class,    levels = class_list)
pred <- factor(predict_class, levels = class_list)
cm <- caret::confusionMatrix(pred, ref)
cm
}
# Plot confusion matrix (percent by reference class)
gcmplot <- function(cm, colors = c(low="white", high="#009194"), title = NULL, prop = TRUE) {
tab <- cm$table  # rows = Prediction, cols = Reference
if (prop) {
# normalize by Reference (columns) => percent within each ground-truth class
colsum <- colSums(tab)
tab <- round(sweep(tab, 2, colsum, "/") * 100, 1)
}
# IMPORTANT: convert matrix -> long table (Prediction, Reference, Freq)
plt <- as.data.frame(as.table(tab))
colnames(plt) <- c("Prediction", "Reference", "Freq")
plt$Prediction <- factor(plt$Prediction, levels = rownames(cm$table))
plt$Reference  <- factor(plt$Reference,  levels = rev(colnames(cm$table)))
ggplot(plt, aes(x = Prediction, y = Reference, fill = Freq)) +
geom_tile() +
geom_text(aes(label = Freq), size = 5) +
scale_fill_gradient(low = colors[1], high = colors[2]) +
labs(x = NULL, y = NULL, fill = if (prop) "Pct (%)" else "Count") +
ggtitle(title) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(hjust = 0.5),
panel.grid = element_blank()
)
}
# Extract a clean metrics row from confusionMatrix
metrics_from_cm <- function(cm, method_name) {
# cm$byClass is named by positive class. With 2-class factors, caret uses the first level as "positive".
# We set levels=c(1,0), so positive = 1 (leaf).
# To avoid confusion, we compute BOTH leaf and wood F1 by flipping once.
overall_acc <- unname(cm$overall["Accuracy"])
overall_kap <- unname(cm$overall["Kappa"])
# Leaf as positive (since levels start with 1)
leaf_precision <- unname(cm$byClass["Precision"])
leaf_recall    <- unname(cm$byClass["Recall"])
leaf_f1        <- unname(cm$byClass["F1"])
# Wood as positive: rebuild confusion with flipped levels (0,1)
tab <- cm$table
# rebuild vectors
ref_vec  <- rep(colnames(tab), each = nrow(tab))
pred_vec <- rep(rownames(tab), times = ncol(tab))
counts   <- as.vector(tab)
# expand (safe enough for workshop; for huge n, this is heavy, but fine here)
ref_exp  <- rep(ref_vec,  counts)
pred_exp <- rep(pred_vec, counts)
cm_wood <- confmatrix_classication(ref_exp, pred_exp, class_list = c(0, 1))
wood_precision <- unname(cm_wood$byClass["Precision"])
wood_recall    <- unname(cm_wood$byClass["Recall"])
wood_f1        <- unname(cm_wood$byClass["F1"])
data.table(
Method = method_name,
Accuracy = overall_acc,
Kappa = overall_kap,
Precision_wood = wood_precision,
Recall_wood = wood_recall,
F1_wood = wood_f1,
Precision_leaf = leaf_precision,
Recall_leaf = leaf_recall,
F1_leaf = leaf_f1
)
}
# Read LAS safely and keep only needed columns
read_ref_dt <- function(path) {
las <- readLAS(path, select = "xyzic") # xyz + intensity + classification if exists
if (is.empty(las)) stop("Reference LAS is empty: ", path)
dt <- as.data.table(las@data)
if (!"Classification" %in% names(dt)) stop("Reference file has no 'Classification' column.")
dt[, .(X, Y, Z, Classification)]
}
# Convert DBSCAN/Graph LAS to dt with pred
read_pred_las_dt <- function(path, method, pwood_threshold = 0.9) {
las <- readLAS(path)
if (is.empty(las)) stop("Prediction LAS is empty: ", path)
dt <- as.data.table(las@data)
if ("pred" %in% names(dt)) {
dt[, pred := as.integer(pred)]
} else if ("p_wood" %in% names(dt)) {
# pred=0 wood, pred=1 leaf
dt[, pred := as.integer(p_wood < pwood_threshold)]
} else {
stop(method, " file must contain either 'pred' or 'p_wood'. File: ", path)
}
dt[, .(X, Y, Z, pred)]
}
# Read TLSeparation leaf/wood xyz txt, create dt with pred
read_tlsep_dt <- function(leaf_txt, wood_txt) {
leaf <- fread(leaf_txt, header = FALSE)
wood <- fread(wood_txt, header = FALSE)
setnames(leaf, c("X", "Y", "Z"))
setnames(wood, c("X", "Y", "Z"))
leaf[, pred := 1L]
wood[, pred := 0L]
rbind(leaf, wood, use.names = TRUE)
}
# Merge prediction with reference on XYZ
align_with_reference <- function(ref_dt, pred_dt, method_name) {
merged <- merge(ref_dt, pred_dt, by = c("X", "Y", "Z"))
if (nrow(merged) == 0) {
stop(method_name, ": No matched points after merging by XYZ. Check coordinate precision / rounding.")
}
merged
}
# ----------------------------
# 3) Run evaluation
# ----------------------------
# Check files exist
stop_if_missing(ref_file)
stop_if_missing(dbscan_file)
stop_if_missing(graph_file)
stop_if_missing(tlsep_leaf_txt)
stop_if_missing(tlsep_wood_txt)
cat("\n[1/4] Reading reference...\n")
ref_dt <- read_ref_dt(ref_file)
cat("Reference points:", nrow(ref_dt), "\n")
cat("Reference class counts:\n")
print(table(ref_dt$Classification, useNA = "ifany"))
cat("\n[2/4] Reading predictions...\n")
db_dt <- read_pred_las_dt(dbscan_file, "DBSCAN", pwood_threshold)
gr_dt <- read_pred_las_dt(graph_file,  "Graph",  pwood_threshold)
tl_dt <- read_tlsep_dt(tlsep_leaf_txt, tlsep_wood_txt)
cat("DBSCAN pred points:", nrow(db_dt), "\n")
cat("Graph  pred points:", nrow(gr_dt), "\n")
cat("TLSeparation pred points:", nrow(tl_dt), "\n")
cat("\n[3/4] Aligning by XYZ and computing confusion matrices...\n")
db_m <- align_with_reference(ref_dt, db_dt, "DBSCAN")
gr_m <- align_with_reference(ref_dt, gr_dt, "Graph")
tl_m <- align_with_reference(ref_dt, tl_dt, "TLSeparation")
cat("Matched points (DBSCAN):", nrow(db_m), "\n")
cat("Matched points (Graph):",  nrow(gr_m), "\n")
cat("Matched points (TLSeparation):", nrow(tl_m), "\n")
cm_db <- confmatrix_classication(db_m$Classification, db_m$pred, class_levels)
cm_gr <- confmatrix_classication(gr_m$Classification, gr_m$pred, class_levels)
cm_tl <- confmatrix_classication(tl_m$Classification, tl_m$pred, class_levels)
